# Copy to .env and edit paths/settings for your machine or Kaggle notebook.
PIPELINE_RAW_DIR=pipeline/data/raw
PIPELINE_INTERMEDIATE_DIR=pipeline/data/intermediate
PIPELINE_OUTPUT_DIR=pipeline/data/outputs
PIPELINE_REPORT_DIR=pipeline/data/reports
PIPELINE_CACHE_DIR=pipeline/data/cache

GLASSDOOR_INPUT=pipeline/data/raw/all_glassdoor_reviews.csv
AMBITIONBOX_INPUT=pipeline/data/raw/all_ambitionbox_reviews.csv

KEYWORD_MAX_FEATURES=2500
KEYWORD_MIN_DF=2
KEYWORD_NGRAM_MAX=3

# paper_embedding_expanded follows category_keyword_extension_final.py:
# category seed centroids + SentenceTransformer similarity over keywords.csv.
# paper_exact writes only the exact category seed list to seed.json.
SEED_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
SEED_BACKEND=paper_embedding_expanded
SEED_SIMILARITY_THRESHOLD=0.60
SEED_TOP_N_PER_CATEGORY=250

# auto tries SentenceTransformer first and falls back to TF-IDF if unavailable.
CLASSIFICATION_BACKEND=auto
CLASSIFICATION_THRESHOLD=0.50
TFIDF_CLASSIFICATION_THRESHOLD=0.10
HR_CATEGORY_KEYS=economic_psychological_benefits,workplace_environment_culture_relationships,job_satisfaction,justice,employee_brand_identification
EMBEDDING_BATCH_SIZE=64
BATCH_SIZE=10000
MAX_ROWS=0

RUN_CLUSTERING=false
CLUSTER_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
CLUSTER_REDUCER=umap
CLUSTER_ALGORITHM=hdbscan
CLUSTER_UMAP_COMPONENTS=10
CLUSTER_UMAP_NEIGHBORS=15
CLUSTER_UMAP_MIN_DIST=0.0
CLUSTER_MIN_CLUSTER_SIZE=15
CLUSTER_MIN_SAMPLES=5
CLUSTER_RANDOM_STATE=42

# Optional linguistic enrichment. Keep false unless spaCy model is installed.
USE_SPACY=false
SPACY_MODEL=en_core_web_sm

# Reserved toggle for later Llama-based labeling/validation.
LLAMA_ENABLED=false
LLAMA_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
